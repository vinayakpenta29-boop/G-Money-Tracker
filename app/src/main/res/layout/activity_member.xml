<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F4F4F4">

    <TextView android:id="@+id/tvMemberTitle"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="22sp" android:textStyle="bold" android:textColor="#333"
        android:textAlignment="center" android:layout_marginBottom="16dp"/>

    <TextView android:id="@+id/tvStatementSummary"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="16sp" android:textColor="#333"
        android:background="@android:color/white" android:padding="16dp"
        android:layout_marginBottom="16dp" android:elevation="2dp"/>

    <TextView
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Transaction History" android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <ListView android:id="@+id/lvMemberTransactions"
        android:layout_width="match_parent" android:layout_height="match_parent"/>

</LinearLayout>
